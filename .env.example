# Polymarket API credentials (required for live trading only)
# Generate via: client.create_or_derive_api_creds()
POLYMARKET_PRIVATE_KEY=your_ed25519_private_key_here
POLYMARKET_FUNDER_ADDRESS=your_polygon_wallet_address_here

# Chain (137 = Polygon mainnet)
CHAIN_ID=137

# Trading mode: "paper" or "live"
TRADING_MODE=paper
